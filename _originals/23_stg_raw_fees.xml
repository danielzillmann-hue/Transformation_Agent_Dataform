<pipeline name="stg_raw_fees">
    <connections>
        <connection name="super_db" type="oracle" host="35.201.6.195" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_tx" connection="super_db">
            <query>SELECT transaction_id, account_id, transaction_date, amount, description FROM transactions WHERE transaction_type LIKE '%Fee%'</query>
        </extract>
        <execute_sql id="clean_stg" connection="super_db">
            <query>TRUNCATE TABLE stg_raw_fees</query>
        </execute_sql>
        <load input="ext_tx" type="oracle" table="stg_raw_fees" connection="super_db"/>
    </steps>
</pipeline>