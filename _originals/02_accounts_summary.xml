<pipeline name="accounts_summary">
    <connections>
        <connection name="super_db" type="oracle" host="34.151.82.212" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_accounts" connection="super_db">
            <query>SELECT account_id, member_id, account_type_id, status, open_date FROM accounts</query>
        </extract>
        <extract id="ext_members" connection="super_db">
            <query>SELECT member_id, first_name, last_name FROM members</query>
        </extract>
        <extract id="ext_types" connection="super_db">
            <query>SELECT account_type_id, type_name FROM account_types</query>
        </extract>
        
        <join id="join_acc_members" left="ext_accounts" right="ext_members" on="MEMBER_ID" how="left"/>
        <join id="join_full" left="join_acc_members" right="ext_types" on="ACCOUNT_TYPE_ID" how="left"/>
        
        <load input="join_full" type="csv" path="accounts_summary.csv"/>
    </steps>
</pipeline>
