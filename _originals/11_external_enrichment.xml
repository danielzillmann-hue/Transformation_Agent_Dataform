<pipeline name="external_enrichment">
    <connections>
        <connection name="super_db" type="oracle" host="35.201.6.195" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_opts" connection="super_db">
            <query>SELECT investment_id, option_name, risk_level FROM investment_options</query>
        </extract>
        <extract_csv id="ext_benchmarks" path="../data/market_benchmarks.csv"/>
        <join id="join_enrich" left="ext_opts" right="ext_benchmarks" on="RISK_LEVEL" how="left"/>
        <transform id="sim_perf" input="join_enrich">
            <simulate_performance/>
            <math operation="subtract" col1="YTD_RETURN_PCT" col2="MARKET_BENCHMARK_RETURN" result_column="PERFORMANCE_VS_BENCHMARK"/>
        </transform>
        <load input="sim_perf" type="csv" path="enriched_investment_performance.csv"/>
    </steps>
</pipeline>
