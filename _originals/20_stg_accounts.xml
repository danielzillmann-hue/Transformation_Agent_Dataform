<pipeline name="stg_accounts">
    <connections>
        <connection name="super_db" type="oracle" host="35.201.6.195" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_accounts" connection="super_db">
            <query>SELECT account_id, member_id, account_type_id, status, open_date FROM accounts</query>
        </extract>
        <execute_sql id="clean_stg" connection="super_db">
            <query>TRUNCATE TABLE stg_accounts</query>
        </execute_sql>
        <load input="ext_accounts" type="oracle" table="stg_accounts" connection="super_db"/>
    </steps>
</pipeline>