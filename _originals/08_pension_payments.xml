<pipeline name="pension_payments">
    <connections>
        <connection name="super_db" type="oracle" host="35.201.6.195" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_tx" connection="super_db">
            <query>SELECT account_id, amount, transaction_type FROM transactions</query>
        </extract>
        <transform id="filter_pension" input="ext_tx">
            <filter condition="TRANSACTION_TYPE == 'Pension Payment'"/>
        </transform>
        <aggregate id="agg_pension" input="filter_pension" group_by="ACCOUNT_ID">
            <sum column="AMOUNT" result_column="TOTAL_PAYMENTS"/>
        </aggregate>
        <transform id="sort_payments" input="agg_pension">
            <sort column="TOTAL_PAYMENTS" ascending="False"/>
        </transform>
        <load input="sort_payments" type="csv" path="pension_payments.csv"/>
    </steps>
</pipeline>
