<pipeline name="active_member_addresses">
    <connections>
        <connection name="super_db" type="oracle" host="35.201.6.195" port="1521" service="XEPDB1" user="superuser" password="superpassword"/>
    </connections>
    <steps>
        <extract id="ext_active_addr" connection="super_db">
            <query>SELECT member_id, address_line, city, state, postcode FROM member_addresses WHERE is_current = 1</query>
        </extract>
        <load input="ext_active_addr" type="csv" path="active_member_addresses.csv"/>
    </steps>
</pipeline>
